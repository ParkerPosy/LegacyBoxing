{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Local",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/pages/courses/boxing/",
        "http://localhost:4173/pages/courses/mma/",
        "http://localhost:4173/pages/courses/youth-programs/",
        "http://localhost:4173/pages/courses/private-training/",
        "http://localhost:4173/pages/courses/schedule/",
        "http://localhost:4173/pages/membership/",
        "http://localhost:4173/pages/gallery/",
        "http://localhost:4173/pages/contact/",
        "http://localhost:4173/pages/events/keystone-games/",
        "http://localhost:4173/pages/articles/",
        "http://localhost:4173/pages/articles/legacy-boxing-hosts-keystone-games-2026/",
        "http://localhost:4173/pages/penn-state/"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.9 }],
        "categories:accessibility":   ["error", { "minScore": 0.9 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.9 }],
        "categories:seo":             ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
